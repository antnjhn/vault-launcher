{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "vault-launcher",
  "version": "0.1.0",
  "identifier": "com.vault.launcher",
  "build": {
    "frontendDist": "../src/renderer",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "VAULT",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' ipc: http://ipc.localhost asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data: blob: https://*.steamstatic.com https://*.steampowered.com;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "$APPDATA/**", "$APPCONFIG/**", "$APPDATA/com.tauri.dev/**", "C:/**", "*"]
      }
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
